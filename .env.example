# -------- API metadata --------
PROJECT_NAME=Hate Speech Detection API
VERSION=1.0.0
DESCRIPTION=Context-aware hate speech detector with feedback loop
API_PREFIX=/api/v1

# -------- Serving model --------
MODEL_DIR=models/transformer/latest
BASE_MODEL_NAME=distilbert-base-uncased
NUM_LABELS=3
MAX_LENGTH=128
SENTENCE_BERT_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# -------- Data / DB --------
# Railway Postgres example:
# DATABASE_URL=postgresql://postgres:password@host:5432/railway
# SQLite fallback for local/single-file usage:
DATABASE_URL=sqlite:///./hate_speech.db

# -------- CORS / API docs --------
# Comma-separated list for multiple origins.
ALLOWED_ORIGINS=https://your-frontend.vercel.app
ENABLE_API_DOCS=false

# -------- Redis --------
# Prefer REDIS_URL for Redis Cloud.
REDIS_URL=redis://default:password@your-redis-host:6379/0
# If REDIS_URL is set, the fields below are ignored.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false
